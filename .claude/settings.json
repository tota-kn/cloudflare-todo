{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(touch:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(pnpm:*)",
      "Bash(ls:*)",
      "mcp__serena",
      "mcp__cloudflare-docs",
      "mcp__context7",
      "WebSearch",
      "WebFetch",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(gh pr:*)"
    ],
    "deny": [
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git branch -D:*)",
      "Bash(git clean:*)",
      "Bash(sudo:*)",
      "Bash(wrangler:*)",
      "Bash(pnpx:*)",
      "Read(.env.*)"
    ],
    "ask": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  },
  "enabledMcpjsonServers": [
    "playwright",
    "cloudflare-observability",
    "cloudflare-docs",
    "serena",
    "context7"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ 作業完了 - 確認をお願いします'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  }
}
